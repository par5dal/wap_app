{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "What a Plan! (Web - 5173)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome",
                "--web-port",
                "5173"
            ]
        },
        {
            "name": "WAP – Development (Android)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "args": [
                "--flavor",
                "development",
                "--dart-define=ENV=development"
            ]
        },
        {
            "name": "WAP – Production (Android)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--flavor",
                "production",
                "--dart-define=ENV=production"
            ]
        },
        {
            "name": "WAP – Production (iOS)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--dart-define=ENV=production"
            ]
        }
    ]
}